# GuideForge — required environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Supabase (public — exposed to the browser; read with process.env.NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI (server-side only — used by app/api/guideforge/* route handlers)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional cost-control switch read by lib/guideforge/ai-provider-routing.ts
# Set to "true" to force the routing layer to skip OpenAI calls and return mocks.
# Leave unset (or "false") for normal operation.
# AI_COST_CAP_EXCEEDED=false
